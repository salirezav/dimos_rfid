# Copy to a private .env (gitignored) and fill in locally:
#   cp .env.example .env
#   nano .env
#
# Never put real keys in this file — it may be committed.

ROBOT_IP=
RFID_API_BASE=http://YOUR_GO2_IP:8765/api/v1

# Gemini (Google AI Studio) — used by: run_semantic_rfid.py --agentic
GOOGLE_API_KEY=
RFID_AGENT_MODEL=google_genai:gemini-2.0-flash

# Optional OpenAI instead of Gemini
# OPENAI_API_KEY=
# RFID_AGENT_MODEL=gpt-4o
